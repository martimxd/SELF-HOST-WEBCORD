# Copy this file to .env or run ./scripts/generate-env.sh.
# Never commit the resulting .env file.

NODE_ENV=production

POSTGRES_DB=webcord
POSTGRES_USER=webcord
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

JWT_SECRET=CHANGE_ME_JWT_SECRET

# Exact browser origin. Change this for LAN or public deployment.
WEB_ORIGIN=http://localhost:3000
WEB_PORT=3000

# The API and LiveKit server must use the same pair.
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET

# Optional GIF search. Create a key at https://developers.giphy.com/
GIPHY_API_KEY=
GIPHY_RATING=pg-13
GIPHY_COUNTRY_CODE=PT

# Media optimization. Images are compressed when possible and lightweight
# thumbnails are generated for previews. Videos are stored safely and streamed
# with range requests.
MEDIA_OPTIMIZATION_ENABLED=true
MEDIA_IMAGE_MAX_WIDTH=1920
MEDIA_IMAGE_QUALITY=82
MEDIA_THUMBNAIL_WIDTH=480
UPLOAD_CLEANUP_ENABLED=false
UPLOAD_RETENTION_DAYS=365

# Same-origin defaults work without changing these.
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_LIVEKIT_URL=
